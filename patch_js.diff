        function setupGlobalSearch() {
            const searchInput = document.getElementById('globalSearch');
            const clearBtn = document.getElementById('clearGlobalSearch');
            const announcement = document.getElementById('searchAnnouncement');

            searchInput.addEventListener('input', (e) => {
                const q = e.target.value.toLowerCase();
                let count = 0;
                document.querySelectorAll('[data-searchable]').forEach(el => {
                    const match = !q || el.dataset.searchable.includes(q);
                    el.style.display = match ? '':'none';
                    if (match) count++;
                });

                clearBtn.style.display = q ? 'block' : 'none';
                announcement.textContent = q ? (count === 1 ? "1 result found." : count + " results found.") : "";
            });

            clearBtn.addEventListener('click', () => {
                searchInput.value = '';
                searchInput.dispatchEvent(new Event('input'));
                searchInput.focus();
            });
        }
